---
import { LOCALES, LOCALE_LABELS, getLocaleFromPathname, localizePath } from '../utils/i18n';

const { pathname } = Astro.url;
const currentLang = getLocaleFromPathname(pathname);
---

<div class="lang-picker" aria-label="Language picker">
	{
		LOCALES.map((locale) => (
			<a
				href={localizePath(pathname, locale)}
				class:list={['lang-link', { active: locale === currentLang }]}
				aria-current={locale === currentLang ? 'page' : undefined}
			>
				{LOCALE_LABELS[locale]}
			</a>
		))
	}
</div>

<style>
	.lang-picker {
		display: flex;
		align-items: center;
		gap: 0.4em;
		margin-right: 1em;
	}

	.lang-link {
		padding: 0.4em 0.8em !important;
		border: 2px solid var(--accent) !important;
		border-radius: 999px;
		color: var(--accent) !important;
		text-decoration: none;
		font-weight: bold;
		font-size: 0.9em;
		line-height: 1;
		transition: all 0.2s ease-in-out;
	}

	.lang-link:hover,
	.lang-link.active {
		background-color: var(--accent);
		color: white !important;
	}
</style>
