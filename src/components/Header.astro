---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LanguagePicker from './LanguagePicker.astro';

const pathname = Astro.url.pathname;
const isZh = pathname.startsWith('/zh-tw');

const navLinks = {
	home: { text: isZh ? '首頁' : 'Home', href: isZh ? '/zh-tw/' : '/' },
	cdcp: { text: isZh ? 'CDCP 牙醫' : 'CDCP Guide', href: isZh ? '/zh-tw/cdcp-dentist' : '/cdcp-dentist' },
	services: { text: isZh ? '醫療服務' : 'Services' },
	implants: { text: isZh ? '人工植牙' : 'Dental Implants', href: isZh ? '/zh-tw/dental-implants' : '/dental-implants' },
	braces: { text: isZh ? '隱適美與矯正' : 'Invisalign & Braces', href: isZh ? '/zh-tw/invisalign-braces' : '/invisalign-braces' },
	cleaning: { text: isZh ? '洗牙與檢查' : 'Cleaning & Exam', href: isZh ? '/zh-tw/dental-cleaning' : '/dental-cleaning' },
	extraction: { text: isZh ? '拔智齒' : 'Tooth Extraction', href: isZh ? '/zh-tw/wisdom-tooth-extraction' : '/wisdom-tooth-extraction' },
	cosmetic: { text: isZh ? '美容牙科' : 'Cosmetic Dentistry', href: isZh ? '/zh-tw/cosmetic-dentist' : '/cosmetic-dentist' },
	mandarin: { text: '中文牙醫服務', href: isZh ? '/zh-tw/mandarin-speaking-dentist' : '/mandarin-speaking-dentist' },
	blog: { text: isZh ? '部落格' : 'Blog', href: isZh ? '/zh-tw/blog' : '/blog' },
	clinic: { text: isZh ? '診所官網' : 'Main Clinic', href: 'https://www.canarydentalsurrey.com/' },
	cta: { text: isZh ? 'LINE 預約' : 'Book via LINE', href: 'https://line.me/ti/p/4RpjC2r6Hq' },
};
---

<header>
	<nav>
		<h2><a href={navLinks.home.href}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={navLinks.home.href}>{navLinks.home.text}</HeaderLink>
			<HeaderLink href={navLinks.cdcp.href}>{navLinks.cdcp.text}</HeaderLink>
			<div class="dropdown">
				<button class="dropbtn">{navLinks.services.text}</button>
				<div class="dropdown-content">
					<a href={navLinks.implants.href}>{navLinks.implants.text}</a>
					<a href={navLinks.braces.href}>{navLinks.braces.text}</a>
					<a href={navLinks.cleaning.href}>{navLinks.cleaning.text}</a>
					<a href={navLinks.extraction.href}>{navLinks.extraction.text}</a>
					<a href={navLinks.cosmetic.href}>{navLinks.cosmetic.text}</a>
					<a href={navLinks.mandarin.href}>{navLinks.mandarin.text}</a>
				</div>
			</div>
			<HeaderLink href={navLinks.blog.href}>{navLinks.blog.text}</HeaderLink>
			<a href={navLinks.clinic.href} target="_blank" rel="noopener noreferrer">{navLinks.clinic.text}</a>
		</div>
		<div class="social-links">
			<LanguagePicker />
			<a href={navLinks.cta.href} target="_blank" class="header-cta">
				{navLinks.cta.text}
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.header-cta {
		background-color: var(--accent);
		color: white !important;
		padding: 0.5em 1em;
		border-radius: 8px;
		font-weight: bold;
		text-decoration: none;
		border-bottom: none !important;
	}
	.header-cta:hover {
		background-color: var(--accent-dark);
	}
	/* Dropdown styles */
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropbtn {
		background-color: transparent;
		color: var(--black);
		padding: 1em 0.5em;
		font-size: 1em;
		border: none;
		cursor: pointer;
		font-family: inherit;
		border-bottom: 4px solid transparent;
	}
	.dropdown-content {
		display: none;
		position: absolute;
		background-color: #fff;
		min-width: 200px;
		box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.1);
		z-index: 1;
		border-radius: 8px;
		overflow: hidden;
	}
	.dropdown-content a {
		color: var(--black);
		padding: 12px 16px;
		text-decoration: none;
		display: block;
		border-bottom: none;
	}
	.dropdown-content a:hover {
		background-color: var(--gray-light);
	}
	.dropdown:hover .dropdown-content {
		display: block;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
