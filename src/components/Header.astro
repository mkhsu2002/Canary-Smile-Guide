---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LanguagePicker from './LanguagePicker.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/cdcp-dentist">CDCP Guide</HeaderLink>
			<div class="dropdown">
				<button class="dropbtn">Services</button>
				<div class="dropdown-content">
					<a href="/dental-implants">Dental Implants</a>
					<a href="/invisalign-braces">Invisalign & Braces</a>
					<a href="/dental-cleaning">Cleaning & Exam</a>
					<a href="/wisdom-tooth-extraction">Tooth Extraction</a>
					<a href="/cosmetic-dentist">Cosmetic Dentistry</a>
					<a href="/mandarin-speaking-dentist">中文牙醫服務</a>
				</div>
			</div>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<a href="https://canarydentalsurrey.com" target="_blank" rel="noopener noreferrer">Main Clinic</a>
		</div>
		<div class="social-links">
			<LanguagePicker />
			<a href="https://line.me/ti/p/4RpjC2r6Hq" target="_blank" class="header-cta">
				Book via LINE
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.header-cta {
		background-color: var(--accent);
		color: white !important;
		padding: 0.5em 1em;
		border-radius: 8px;
		font-weight: bold;
		text-decoration: none;
		border-bottom: none !important;
	}
	.header-cta:hover {
		background-color: var(--accent-dark);
	}
	/* Dropdown styles */
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropbtn {
		background-color: transparent;
		color: var(--black);
		padding: 1em 0.5em;
		font-size: 1em;
		border: none;
		cursor: pointer;
		font-family: inherit;
		border-bottom: 4px solid transparent;
	}
	.dropdown-content {
		display: none;
		position: absolute;
		background-color: #fff;
		min-width: 200px;
		box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.1);
		z-index: 1;
		border-radius: 8px;
		overflow: hidden;
	}
	.dropdown-content a {
		color: var(--black);
		padding: 12px 16px;
		text-decoration: none;
		display: block;
		border-bottom: none;
	}
	.dropdown-content a:hover {
		background-color: var(--gray-light);
	}
	.dropdown:hover .dropdown-content {
		display: block;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
