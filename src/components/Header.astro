---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LanguagePicker from './LanguagePicker.astro';

const pathname = Astro.url.pathname;
const isZh = pathname.startsWith('/zh-tw');

const navLinks = {
	home: { text: isZh ? '首頁' : 'Home', href: isZh ? '/zh-tw/' : '/' },
	cdcp: { text: isZh ? 'CDCP 牙醫' : 'CDCP Guide', href: isZh ? '/zh-tw/cdcp-dentist' : '/cdcp-dentist' },
	services: { text: isZh ? '醫療服務' : 'Services' },
	implants: { text: isZh ? '人工植牙' : 'Dental Implants', href: isZh ? '/zh-tw/dental-implants' : '/dental-implants' },
	braces: { text: isZh ? '隱適美與矯正' : 'Invisalign & Braces', href: isZh ? '/zh-tw/invisalign-braces' : '/invisalign-braces' },
	cleaning: { text: isZh ? '洗牙與檢查' : 'Cleaning & Exam', href: isZh ? '/zh-tw/dental-cleaning' : '/dental-cleaning' },
	extraction: { text: isZh ? '拔智齒' : 'Tooth Extraction', href: isZh ? '/zh-tw/wisdom-tooth-extraction' : '/wisdom-tooth-extraction' },
	cosmetic: { text: isZh ? '美容牙科' : 'Cosmetic Dentistry', href: isZh ? '/zh-tw/cosmetic-dentist' : '/cosmetic-dentist' },
	mandarin: { text: '中文牙醫服務', href: isZh ? '/zh-tw/mandarin-speaking-dentist' : '/mandarin-speaking-dentist' },
	blog: { text: isZh ? '部落格' : 'Blog', href: isZh ? '/zh-tw/blog' : '/blog' },
	clinic: { text: isZh ? '診所官網' : 'Main Clinic', href: 'https://www.canarydentalsurrey.com/' },
	cta: { text: isZh ? 'LINE 預約' : 'Book via LINE', href: 'https://line.me/ti/p/4RpjC2r6Hq' },
};
---

<header>
	<nav>
		<!-- Logo + Language (always visible, even on mobile) -->
		<div class="nav-brand">
			<h2><a href={navLinks.home.href}>{SITE_TITLE}</a></h2>
			<LanguagePicker />
		</div>

		<!-- Hamburger toggle (mobile only) -->
		<button class="hamburger" id="hamburger" aria-label="Toggle menu">
			<span></span><span></span><span></span>
		</button>

		<!-- Main nav links (collapsible on mobile) -->
		<div class="nav-links" id="navLinks">
			<HeaderLink href={navLinks.home.href}>{navLinks.home.text}</HeaderLink>
			<HeaderLink href={navLinks.cdcp.href}>{navLinks.cdcp.text}</HeaderLink>
			<div class="dropdown">
				<button class="dropbtn">{navLinks.services.text}</button>
				<div class="dropdown-content">
					<a href={navLinks.implants.href}>{navLinks.implants.text}</a>
					<a href={navLinks.braces.href}>{navLinks.braces.text}</a>
					<a href={navLinks.cleaning.href}>{navLinks.cleaning.text}</a>
					<a href={navLinks.extraction.href}>{navLinks.extraction.text}</a>
					<a href={navLinks.cosmetic.href}>{navLinks.cosmetic.text}</a>
					<a href={navLinks.mandarin.href}>{navLinks.mandarin.text}</a>
				</div>
			</div>
			<HeaderLink href={navLinks.blog.href}>{navLinks.blog.text}</HeaderLink>
			<a href={navLinks.clinic.href} target="_blank" rel="noopener noreferrer">{navLinks.clinic.text}</a>
			<a href={navLinks.cta.href} target="_blank" class="header-cta">
				{navLinks.cta.text}
			</a>
		</div>
	</nav>
</header>

<script>
	const hamburger = document.getElementById('hamburger');
	const navLinks = document.getElementById('navLinks');
	hamburger?.addEventListener('click', () => {
		navLinks?.classList.toggle('open');
		hamburger.classList.toggle('active');
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 0.8em;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Nav links container */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0;
	}

	/* CTA button */
	.header-cta {
		background-color: var(--accent);
		color: white !important;
		padding: 0.5em 1em;
		border-radius: 8px;
		font-weight: bold;
		text-decoration: none;
		border-bottom: none !important;
		margin-left: 0.5em;
	}
	.header-cta:hover {
		background-color: var(--accent-dark);
	}

	/* Dropdown */
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropbtn {
		background-color: transparent;
		color: var(--black);
		padding: 1em 0.5em;
		font-size: 1em;
		border: none;
		cursor: pointer;
		font-family: inherit;
		border-bottom: 4px solid transparent;
	}
	.dropdown-content {
		display: none;
		position: absolute;
		background-color: #fff;
		min-width: 200px;
		box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.1);
		z-index: 10;
		border-radius: 8px;
		overflow: hidden;
	}
	.dropdown-content a {
		color: var(--black);
		padding: 12px 16px;
		text-decoration: none;
		display: block;
		border-bottom: none;
	}
	.dropdown-content a:hover {
		background-color: var(--gray-light);
	}
	.dropdown:hover .dropdown-content {
		display: block;
	}

	/* Hamburger button (hidden on desktop) */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
	}
	.hamburger span {
		display: block;
		width: 24px;
		height: 3px;
		background: var(--black);
		border-radius: 2px;
		transition: all 0.3s ease;
	}
	.hamburger.active span:nth-child(1) {
		transform: rotate(45deg) translate(5px, 6px);
	}
	.hamburger.active span:nth-child(2) {
		opacity: 0;
	}
	.hamburger.active span:nth-child(3) {
		transform: rotate(-45deg) translate(5px, -6px);
	}

	/* === Mobile === */
	@media (max-width: 720px) {
		.hamburger {
			display: flex;
		}
		.nav-links {
			display: none;
			flex-direction: column;
			width: 100%;
			padding-bottom: 1em;
		}
		.nav-links.open {
			display: flex;
		}
		.nav-links a,
		.nav-links .dropbtn {
			width: 100%;
			text-align: center;
			padding: 0.8em 0;
		}
		.dropdown {
			width: 100%;
		}
		.dropdown-content {
			position: static;
			box-shadow: none;
			border-radius: 0;
			background: var(--gray-light);
		}
		.header-cta {
			margin: 0.5em auto;
			display: inline-block;
		}
	}
</style>

