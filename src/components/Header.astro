---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LanguagePicker from './LanguagePicker.astro';
import { getLocaleFromPathname, localizePath, type Locale } from '../utils/i18n';

const pathname = Astro.url.pathname;
const locale = getLocaleFromPathname(pathname);

const navText: Record<Locale, Record<string, string>> = {
	en: {
		home: 'Home',
		cdcp: 'CDCP Guide',
		services: 'Services',
		implants: 'Dental Implants',
		braces: 'Invisalign & Braces',
		cleaning: 'Cleaning & Exam',
		extraction: 'Tooth Extraction',
		cosmetic: 'Cosmetic Dentistry',
		languageCare: 'Chinese & Korean Care',
		blog: 'Blog',
		clinic: 'Main Clinic',
		cta: 'Book via LINE',
	},
	'zh-tw': {
		home: '首頁',
		cdcp: 'CDCP 牙醫',
		services: '醫療服務',
		implants: '人工植牙',
		braces: '隱適美與矯正',
		cleaning: '洗牙與檢查',
		extraction: '拔智齒',
		cosmetic: '美容牙科',
		languageCare: '中文與韓語服務',
		blog: '部落格',
		clinic: '診所官網',
		cta: 'LINE 預約',
	},
	ko: {
		home: '홈',
		cdcp: 'CDCP 안내',
		services: '진료 서비스',
		implants: '임플란트',
		braces: '인비절라인·교정',
		cleaning: '스케일링·검진',
		extraction: '발치',
		cosmetic: '심미치과',
		languageCare: '한국어·중국어 상담',
		blog: '블로그',
		clinic: '본원 홈페이지',
		cta: 'LINE 예약',
	},
};

const navLinks = {
	home: { text: navText[locale].home, href: localizePath('/', locale) },
	cdcp: { text: navText[locale].cdcp, href: localizePath('/cdcp-dentist', locale) },
	services: { text: navText[locale].services },
	implants: { text: navText[locale].implants, href: localizePath('/dental-implants', locale) },
	braces: { text: navText[locale].braces, href: localizePath('/invisalign-braces', locale) },
	cleaning: { text: navText[locale].cleaning, href: localizePath('/dental-cleaning', locale) },
	extraction: { text: navText[locale].extraction, href: localizePath('/wisdom-tooth-extraction', locale) },
	cosmetic: { text: navText[locale].cosmetic, href: localizePath('/cosmetic-dentist', locale) },
	mandarin: { text: navText[locale].languageCare, href: localizePath('/mandarin-speaking-dentist', locale) },
	blog: { text: navText[locale].blog, href: localizePath('/blog', locale) },
	clinic: { text: navText[locale].clinic, href: 'https://www.canarydentalsurrey.com/' },
	cta: { text: navText[locale].cta, href: 'https://line.me/ti/p/4RpjC2r6Hq' },
};
---

<header>
	<nav>
		<!-- Logo + Language (always visible, even on mobile) -->
		<div class="nav-brand">
			<h2><a href={navLinks.home.href}>{SITE_TITLE}</a></h2>
			<LanguagePicker />
		</div>

		<!-- Hamburger toggle (mobile only) -->
		<button class="hamburger" id="hamburger" aria-label="Toggle menu">
			<span></span><span></span><span></span>
		</button>

		<!-- Main nav links (collapsible on mobile) -->
		<div class="nav-links" id="navLinks">
			<HeaderLink href={navLinks.home.href}>{navLinks.home.text}</HeaderLink>
			<HeaderLink href={navLinks.cdcp.href}>{navLinks.cdcp.text}</HeaderLink>
			<div class="dropdown">
				<button class="dropbtn">{navLinks.services.text}</button>
				<div class="dropdown-content">
					<a href={navLinks.implants.href}>{navLinks.implants.text}</a>
					<a href={navLinks.braces.href}>{navLinks.braces.text}</a>
					<a href={navLinks.cleaning.href}>{navLinks.cleaning.text}</a>
					<a href={navLinks.extraction.href}>{navLinks.extraction.text}</a>
					<a href={navLinks.cosmetic.href}>{navLinks.cosmetic.text}</a>
					<a href={navLinks.mandarin.href}>{navLinks.mandarin.text}</a>
				</div>
			</div>
			<HeaderLink href={navLinks.blog.href}>{navLinks.blog.text}</HeaderLink>
			<a href={navLinks.clinic.href} target="_blank" rel="noopener noreferrer">{navLinks.clinic.text}</a>
			<a href={navLinks.cta.href} target="_blank" class="header-cta">
				{navLinks.cta.text}
			</a>
		</div>
	</nav>
</header>

<script>
	const hamburger = document.getElementById('hamburger');
	const navLinks = document.getElementById('navLinks');
	hamburger?.addEventListener('click', () => {
		navLinks?.classList.toggle('open');
		hamburger.classList.toggle('active');
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 0.8em;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Nav links container */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0;
	}

	/* CTA button */
	.header-cta {
		background-color: var(--accent);
		color: white !important;
		padding: 0.5em 1em;
		border-radius: 8px;
		font-weight: bold;
		text-decoration: none;
		border-bottom: none !important;
		margin-left: 0.5em;
	}
	.header-cta:hover {
		background-color: var(--accent-dark);
	}

	/* Dropdown */
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropbtn {
		background-color: transparent;
		color: var(--black);
		padding: 1em 0.5em;
		font-size: 1em;
		border: none;
		cursor: pointer;
		font-family: inherit;
		border-bottom: 4px solid transparent;
	}
	.dropdown-content {
		display: none;
		position: absolute;
		background-color: #fff;
		min-width: 200px;
		box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.1);
		z-index: 10;
		border-radius: 8px;
		overflow: hidden;
	}
	.dropdown-content a {
		color: var(--black);
		padding: 12px 16px;
		text-decoration: none;
		display: block;
		border-bottom: none;
	}
	.dropdown-content a:hover {
		background-color: var(--gray-light);
	}
	.dropdown:hover .dropdown-content {
		display: block;
	}

	/* Hamburger button (hidden on desktop) */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
	}
	.hamburger span {
		display: block;
		width: 24px;
		height: 3px;
		background: var(--black);
		border-radius: 2px;
		transition: all 0.3s ease;
	}
	.hamburger.active span:nth-child(1) {
		transform: rotate(45deg) translate(5px, 6px);
	}
	.hamburger.active span:nth-child(2) {
		opacity: 0;
	}
	.hamburger.active span:nth-child(3) {
		transform: rotate(-45deg) translate(5px, -6px);
	}

	/* === Mobile === */
	@media (max-width: 720px) {
		.hamburger {
			display: flex;
		}
		.nav-links {
			display: none;
			flex-direction: column;
			width: 100%;
			padding-bottom: 1em;
		}
		.nav-links.open {
			display: flex;
		}
		.nav-links a,
		.nav-links .dropbtn {
			width: 100%;
			text-align: center;
			padding: 0.8em 0;
		}
		.dropdown {
			width: 100%;
		}
		.dropdown-content {
			position: static;
			box-shadow: none;
			border-radius: 0;
			background: var(--gray-light);
		}
		.header-cta {
			margin: 0.5em auto;
			display: inline-block;
		}
	}
</style>
