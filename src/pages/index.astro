---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Dentist in Surrey, BC | Canary Smile Guide" description="Looking for a trusted family dentist in Surrey, BC? Canary Dental offers comprehensive care, from cleanings to implants, with English, Mandarin, and Korean-friendly support from our Korean-Canadian dentist and hygienist." />
		<style>
			main {
				width: 100%;
			}
			/* Hero Section */
			.hero-section {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 4em 5%;
				background: linear-gradient(135deg, var(--gray-light) 0%, #ffffff 100%);
				gap: 3em;
			}
			.hero-content {
				flex: 1;
				max-width: 600px;
			}
			.hero-content h1 {
				font-size: 3.5em;
				color: var(--accent);
				margin-bottom: 0.3em;
				line-height: 1.1;
			}
			.hero-content p {
				font-size: 1.2em;
				color: var(--black);
				margin-bottom: 1.5em;
				line-height: 1.6;
			}
			.hero-image {
				flex: 1;
				display: flex;
				justify-content: center;
			}
			.hero-image img {
				max-width: 100%;
				border-radius: 20px;
				box-shadow: 0 20px 40px rgba(0,0,0,0.1);
			}

			/* Quiz Guide Section */
			.quiz-section {
				padding: 5em 5%;
				background-color: var(--accent);
				color: white;
				text-align: center;
			}
			.quiz-section h2 {
				font-size: 2.5em;
				margin-bottom: 1.5em;
				color: white;
			}
			.quiz-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5em;
				max-width: 1200px;
				margin: 0 auto;
			}
			.quiz-card {
				background: white;
				color: var(--black);
				padding: 2em 1em;
				border-radius: 12px;
				text-decoration: none;
				font-weight: bold;
				font-size: 1.1em;
				box-shadow: 0 4px 15px rgba(0,0,0,0.2);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5em;
			}
			.quiz-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 12px 24px rgba(0,0,0,0.3);
				color: var(--accent);
			}
			.quiz-icon {
				font-size: 2.5em;
			}

			/* Services Grid Section */
			.services-section {
				padding: 5em 5%;
				background: #ffffff;
				text-align: center;
			}
			.services-section h2 {
				font-size: 2.5em;
				color: var(--accent);
				margin-bottom: 0.5em;
			}
			.services-intro {
				font-size: 1.1em;
				max-width: 800px;
				margin: 0 auto 3em auto;
			}
			.services-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 2em;
				max-width: 1200px;
				margin: 0 auto;
			}
			.service-card {
				background: var(--gray-light);
				padding: 2em;
				border-radius: 16px;
				text-align: left;
				transition: transform 0.3s ease, background 0.3s ease;
				box-shadow: 0 2px 8px rgba(0,0,0,0.05);
			}
			.service-card:hover {
				transform: translateY(-5px);
				background: #fdf5eb; /* Soft canary yellow tint */
				box-shadow: 0 10px 20px rgba(0,0,0,0.1);
			}
			.service-card h3 {
				color: var(--accent);
				margin-bottom: 0.5em;
			}
			.service-card p {
				color: var(--black);
				font-size: 0.95em;
				line-height: 1.5;
			}
			.service-card a {
				display: inline-block;
				margin-top: 1em;
				font-weight: bold;
				color: var(--accent);
				text-decoration: none;
			}
			.service-card a:hover {
				text-decoration: underline;
			}

			/* Trust & FAQ */
			.trust-section {
				padding: 5em 5%;
				background: var(--gray-light);
			}
			.trust-content {
				max-width: 900px;
				margin: 0 auto;
			}
			.faq details {
				background: white;
				padding: 1.5em;
				border-radius: 8px;
				margin-bottom: 1em;
				box-shadow: 0 2px 5px rgba(0,0,0,0.05);
			}
			.faq summary {
				font-weight: bold;
				cursor: pointer;
				font-size: 1.1em;
				color: var(--black);
			}
			.faq p {
				margin-top: 1em;
				line-height: 1.6;
				color: #4a4a4a;
			}

			@media (max-width: 768px) {
				.hero-section {
					flex-direction: column;
					text-align: center;
					padding: 3em 5%;
				}
				.hero-content h1 {
					font-size: 2.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero-section">
				<div class="hero-content">
					<h1>Your Trusted Dental Health Guide in Surrey, BC</h1>
					<p>
						Welcome to Canary Smile Guide—a free educational platform established by the dental professionals at Canary Dental Clinic. Our goal is to empower the public with trustworthy oral health knowledge, promote preventative care, and share our core philosophy. Through education, we hope to build lasting trust and demonstrate our commitment to your health before you even walk through our doors for comprehensive care in English, Mandarin, and Korean, including support from our Korean-Canadian dentist and hygienist.
					</p>
					<a href="https://line.me/ti/p/4RpjC2r6Hq" class="cta-button" style="display:inline-block; background:var(--accent); color:white; padding:1em 2em; border-radius:8px; text-decoration:none; font-weight:bold; font-size:1.1em; transition: 0.3s;">Book Your Consultation</a>
					<p style="margin-top:1.2em; font-size:0.95em; line-height:1.8; opacity:0.85;">
						📍 <a href="https://maps.google.com/?q=14920+104+Ave,+Surrey,+BC+V3R+1M7" style="color:inherit;" target="_blank" rel="noopener noreferrer">14920 104 Ave, Surrey, BC V3R 1M7</a><br>
						📞 <a href="tel:+16044960392" style="color:inherit;">(604) 496-0392</a><br>
						🌐 <a href="https://www.canarydentalsurrey.com/" style="color:inherit;" target="_blank" rel="noopener noreferrer">www.canarydentalsurrey.com</a>
					</p>
				</div>
				<div class="hero-image">
					<img src="/images/hero-bg.jpg" alt="Happy patient smiling confidently in a bright modern dental clinic" />
				</div>
			</section>

			<!-- Quiz Guide Section -->
			<section class="quiz-section">
				<h2>What can we help you with today?</h2>
				<div class="quiz-grid">
					<a href="/wisdom-tooth-extraction" class="quiz-card">
						<img src="/images/icon_toothache.jpg" alt="Emergency" width="48" height="48" />
						I'm in pain right now
					</a>
					<a href="/cosmetic-dentist" class="quiz-card">
						<img src="/images/icon_whitening.jpg" alt="Whitening" width="48" height="48" />
						I want a brighter smile
					</a>
					<a href="/dental-implants" class="quiz-card">
						<img src="/images/icon_implant.jpg" alt="Implants" width="48" height="48" />
						I'm missing a tooth
					</a>
					<a href="/dental-cleaning" class="quiz-card">
						<img src="/images/icon_checkup.jpg" alt="Checkup" width="48" height="48" />
						I need a check-up
					</a>
					<a href="/cdcp-dentist" class="quiz-card">
						<img src="/images/icon_cdcp.jpg" alt="CDCP" width="48" height="48" />
						Use CDCP benefits
					</a>
				</div>
			</section>

			<!-- Services Grid -->
			<section class="services-section">
				<h2>Comprehensive Dental Services</h2>
				<p class="services-intro">We provide transparent, preventative, and patient-centered dentistry. Our Surrey clinic is fully equipped to help you achieve optimal oral health.</p>
				<div class="services-grid">
					<div class="service-card">
						<h3>Preventative Care</h3>
						<p>Thorough exams, digital X-rays, and professional scaling to keep your gums healthy and prevent cavities.</p>
						<a href="/dental-cleaning">Learn more &rarr;</a>
					</div>
					<div class="service-card">
						<h3>Dental Implants</h3>
						<p>Permanent, natural-looking solutions for missing teeth using premium Straumann BLX implants.</p>
						<a href="/dental-implants">Learn more &rarr;</a>
					</div>
					<div class="service-card">
						<h3>Orthodontics</h3>
						<p>Clear Invisalign aligners and traditional braces for both adults and children needing early intervention.</p>
						<a href="/invisalign-braces">Learn more &rarr;</a>
					</div>
					<div class="service-card">
						<h3>Oral Surgery</h3>
						<p>Safe and comfortable removal of impacted wisdom teeth with minimal downtime and expert aftercare.</p>
						<a href="/wisdom-tooth-extraction">Learn more &rarr;</a>
					</div>
					<div class="service-card">
						<h3>Dental Costs Guide</h3>
						<p>How much does dental care cost in Canada vs. Taiwan & Asia? A transparent cost comparison for immigrants.</p>
						<a href="/blog/dental-costs-canada-vs-taiwan">Learn more &rarr;</a>
					</div>
					<div class="service-card">
						<h3>Materials & Brands</h3>
						<p>Understanding Straumann BLX, Invisalign, and dental material certifications. Know what you are paying for.</p>
						<a href="/blog/dental-materials-brand-guide">Learn more &rarr;</a>
					</div>
				</div>
			</section>

			<!-- Trust & FAQ -->
			<section class="trust-section">
				<div class="trust-content">
					<h2 style="text-align:center; color:var(--accent); margin-bottom: 1.5em; font-size: 2.5em;">Frequently Asked Questions</h2>
					<div class="faq">
						<details>
							<summary>Are you currently accepting new patients in Surrey?</summary>
							<p>Yes, we are warmly welcoming new patients and families to our clinic. Contact us today to schedule your comprehensive initial exam.</p>
						</details>
						<details>
							<summary>Do you accept the new Canadian Dental Care Plan (CDCP)?</summary>
							<p>Absolutely. We are a registered CDCP provider. Please bring your CDCP card and a valid piece of ID to your first appointment, and our front desk will help you verify your coverage.</p>
						</details>
						<details>
							<summary>Do you have Mandarin- or Korean-speaking dental staff?</summary>
							<p>Yes. We have a fluent Mandarin-speaking team, and we also have a Korean-Canadian dentist and hygienist who can support patients in Korean. 한국어 상담도 가능합니다. We want you to fully understand your treatment plan without language barriers. <a href="/mandarin-speaking-dentist" style="color:var(--accent); font-weight:bold;">Learn more</a>.</p>
						</details>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>
