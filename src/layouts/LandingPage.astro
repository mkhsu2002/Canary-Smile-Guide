---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = {
	title: string;
	description: string;
	lang?: string;
};

const { title, description, lang = 'en' } = Astro.props;
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} lang={lang} />
		<style>
			main {
				width: 100%;
				max-width: 900px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.hero {
				text-align: center;
				padding: 3em 0 2em 0;
			}
			.hero h1 {
				font-size: 3em;
				color: var(--accent);
				margin-bottom: 0.2em;
			}
			.content-section {
				background: #fff;
				padding: 2em;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				margin-bottom: 2em;
			}
			.cta-container {
				text-align: center;
				margin: 3em 0;
			}
			.cta-button {
				display: inline-block;
				background-color: var(--accent);
				color: white;
				padding: 1em 2em;
				border-radius: 10px;
				text-decoration: none;
				font-weight: bold;
				font-size: 1.2em;
				transition: background-color 0.3s;
			}
			.cta-button:hover {
				background-color: var(--accent-dark);
				color: white;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
